<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="24dp">
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Settings" android:textSize="26sp" android:textStyle="bold" />
    <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/darkModeSwitch" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Dark mode" android:layout_marginTop="20dp" />
    <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/offlineSwitch" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Offline sync" android:checked="true" />
    <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/notificationSwitch" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Bus alerts" android:checked="true" />
</LinearLayout>
