<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">
    <fragment android:id="@+id/splashFragment" android:name="com.vidyavahini.app.ui.splash.SplashFragment" android:label="Splash">
        <action android:id="@+id/action_splash_to_login" app:destination="@id/loginFragment" app:popUpTo="@id/splashFragment" app:popUpToInclusive="true" />
        <action android:id="@+id/action_splash_to_home" app:destination="@id/homeFragment" app:popUpTo="@id/splashFragment" app:popUpToInclusive="true" />
    </fragment>
    <fragment android:id="@+id/loginFragment" android:name="com.vidyavahini.app.ui.auth.LoginFragment" android:label="Login">
        <action android:id="@+id/action_login_to_signup" app:destination="@id/signupFragment" />
        <action android:id="@+id/action_login_to_home" app:destination="@id/homeFragment" app:popUpTo="@id/loginFragment" app:popUpToInclusive="true" />
    </fragment>
    <fragment android:id="@+id/signupFragment" android:name="com.vidyavahini.app.ui.auth.SignupFragment" android:label="Signup">
        <action android:id="@+id/action_signup_to_home" app:destination="@id/homeFragment" app:popUpTo="@id/loginFragment" app:popUpToInclusive="true" />
    </fragment>
    <fragment android:id="@+id/homeFragment" android:name="com.vidyavahini.app.ui.home.HomeFragment" android:label="Home" />
    <fragment android:id="@+id/routeSelectionFragment" android:name="com.vidyavahini.app.ui.routes.RouteSelectionFragment" android:label="Routes" />
    <fragment android:id="@+id/liveTrackingFragment" android:name="com.vidyavahini.app.ui.tracking.LiveTrackingFragment" android:label="Tracking" />
    <fragment android:id="@+id/notificationsFragment" android:name="com.vidyavahini.app.ui.notifications.NotificationsFragment" android:label="Notifications" />
    <fragment android:id="@+id/assistantFragment" android:name="com.vidyavahini.app.ui.assistant.AssistantFragment" android:label="Assistant" />
    <fragment android:id="@+id/profileFragment" android:name="com.vidyavahini.app.ui.profile.ProfileFragment" android:label="Profile" />
    <fragment android:id="@+id/emergencyFragment" android:name="com.vidyavahini.app.ui.emergency.EmergencyFragment" android:label="Emergency" />
    <fragment android:id="@+id/settingsFragment" android:name="com.vidyavahini.app.ui.settings.SettingsFragment" android:label="Settings" />
</navigation>
